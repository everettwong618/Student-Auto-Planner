# Copy this file to .streamlit/secrets.toml for local development.
# In Streamlit Community Cloud, paste the same values into App settings -> Secrets.

SUPABASE_URL = "https://your-project-ref.supabase.co"
SUPABASE_ANON_KEY = "your-anon-public-key"

# The app also accepts this nested form:
# [supabase]
# url = "https://your-project-ref.supabase.co"
# anon_key = "your-anon-public-key"
